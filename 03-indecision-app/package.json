    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.35.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
